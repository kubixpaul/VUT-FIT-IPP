<?xml version="1.0" encoding="UTF-8"?>
<program language="SOL26">

  <class name="A" parent="Object">
    <method selector="m">
      <block arity="0">
        <assign order="1">
          <var name="_"/>
          <expr>
            <send selector="print">
              <expr><literal class="String" value="A"/></expr>
            </send>
          </expr>
        </assign>
      </block>
    </method>
  </class>

  <class name="B" parent="A">
    <method selector="m">
      <block arity="0">

        <assign order="1">
          <var name="_"/>
          <expr>
            <send selector="m">
              <expr><var name="super"/></expr>
            </send>
          </expr>
        </assign>

        <assign order="2">
          <var name="_"/>
          <expr>
            <send selector="print">
              <expr><literal class="String" value="B"/></expr>
            </send>
          </expr>
        </assign>

      </block>
    </method>
  </class>

  <class name="Main" parent="Object">
    <method selector="run">
      <block arity="0">

        <assign order="1">
          <var name="b"/>
          <expr>
            <send selector="new">
              <expr><literal class="class" value="B"/></expr>
            </send>
          </expr>
        </assign>

        <assign order="2">
          <var name="_"/>
          <expr>
            <send selector="m">
              <expr><var name="b"/></expr>
            </send>
          </expr>
        </assign>

      </block>
    </method>
  </class>

</program>